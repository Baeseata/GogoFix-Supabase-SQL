  -- \uc0\u30001 \u23458 \u25143 \u31471 \u35745 \u31639 \u21518 \u20256 \u20837 \u65292 \u25968 \u25454 \u24211 \u19981 \u20570 \u33258 \u21160 \u27719 \u24635 \
  cost_delta numeric(10,2) NOT NULL DEFAULT 0,\
\
  -- \uc0\u30424 \u28857 \u22791 \u27880  / \u21407 \u22240 \u35828 \u26126 \
