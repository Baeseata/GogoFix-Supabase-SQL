DO $$\
BEGIN\
  -- \uc0\u27169 \u31946 \u24211 \u23384 \u27700 \u20301 \u26522 \u20030 \u65292 \u29992 \u20110  untracked \u27169 \u24335 \u21830 \u21697 \u65306 \
  --   empty    = \uc0\u26080 \u36135 \
  --   very_few = \uc0\u26497 \u23569 \u65288 \u24555 \u26029 \u36135 \u65289 \
  --   few      = \uc0\u23569 \u37327 \
  --   normal   = \uc0\u24211 \u23384 \u27491 \u24120 \
  --   too_much = \uc0\u24211 \u23384 \u36807 \u22810 \u65288 \u31215 \u21387 \u65289 \
  CREATE TYPE public.stock_bucket AS ENUM ('empty', 'very_few', 'few', 'normal', 'too_much');\
EXCEPTION\
  WHEN duplicate_object THEN NULL;\
END $$;\
