  customer_id uuid PRIMARY KEY,\
\
  -- \uc0\u23458 \u25143 \u22995 \u21517 \u65292 \u20801 \u35768 \u20026 \u31354 \u65288 \u21311 \u21517 \u23458 \u25143  / \u31245 \u21518 \u34917 \u22635 \u65289 \
  customer_name text DEFAULT NULL,\
\
  -- \uc0\u23458 \u25143 \u22791 \u27880 \u25551 \u36848 \
  description text DEFAULT NULL,\
\
  -- \uc0\u25163 \u26426 \u21495 \u30721 \u65292 \u20197 \u25991 \u26412 \u23384 \u20648 \u65307 NULL \u34920 \u31034 \u26410 \u30693 \
  -- \uc0\u27963 \u36291 \u23458 \u25143 \u20013 \u25163 \u26426 \u21495 \u21807 \u19968 \u65288 \u35265 \u19979 \u26041  partial unique index\u65289 \u65292 \u36719 \u21024 \u38500 \u21518 \u37322 \u25918 \u21495 \u30721 \u21487 \u34987 \u26032 \u23458 \u25143 \u20351 \u29992 \
  -- \uc0\u31163 \u32447 \u20914 \u31361 \u22788 \u29702 \u65306 \u20004 \u20010 \u38376 \u24215 \u31163 \u32447 \u29992 \u21516 \u19968 \u25163 \u26426 \u21495 \u24314 \u23458 \u25143 \u65292 \u21516 \u27493 \u26102 \u31532 \u20108 \u26465 \u20250 \u34987 \u21807 \u19968 \u32422 \u26463 \u25318 \u20303 \u65292 \
  -- \uc0\u24212 \u29992 \u23618 \u38656 \u22788 \u29702 \u20914 \u31361 \u21709 \u24212 \u65288 \u25552 \u31034 \u21512 \u24182 \u25110 \u25918 \u24323 \u65289 \
  phone_number text DEFAULT NULL,\
\
  -- \uc0\u32531 \u23384 \u23383 \u27573 \u65306 \u35813 \u23458 \u25143 \u22312 \u25152 \u26377 \u38376 \u24215 \u30340 \u20313 \u39069 \u21512 \u35745 \
