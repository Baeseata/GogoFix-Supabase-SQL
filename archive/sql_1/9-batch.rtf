-- =========================================\
-- 0) batch_id \uc0\u25353  store_id \u20998 \u32452 \u33258 \u21160 \u20998 \u37197 \u20989 \u25968 \
-- =========================================\
-- \uc0\u21516 \u19968  store_id \u19979 \u65292 batch_id \u20174  1 \u24320 \u22987 \u20381 \u27425 \u36882 \u22686 \
-- \uc0\u20351 \u29992 \u34892 \u32423 \u21672 \u35810 \u38145 \u38450 \u27490 \u24182 \u21457 \u25554 \u20837 \u20135 \u29983 \u37325 \u22797 \u32534 \u21495 \
CREATE OR REPLACE FUNCTION public.assign_batch_id_per_store()\
RETURNS trigger\
LANGUAGE plpgsql\
AS $$\
DECLARE\
  next_bid int;\
BEGIN\
  IF NEW.store_id IS NULL THEN\
    RAISE EXCEPTION 'store_id cannot be null';\
  END IF;\
\
  -- \uc0\u21672 \u35810 \u38145 \u65306 \u21629 \u21517 \u31354 \u38388  1002\u65292 \u36991 \u20813 \u21644 \u20854 \u20182 \u38145 \u20914 \u31361 \
  PERFORM pg_advisory_xact_lock(1002, hashtext(NEW.store_id));\
\
  SELECT COALESCE(MAX(batch_id), 0) + 1\
    INTO next_bid\
  FROM public.batch_list\
  WHERE store_id = NEW.store_id;\
\
  NEW.batch_id := next_bid;\
  RETURN NEW;\
END;\
$$;\
\
